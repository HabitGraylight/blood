{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "userGameResults": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$gameId": {
          ".write": "auth != null && (auth.uid === $uid || root.child('replays/' + $gameId + '/createdBy').val() === auth.uid)"
        }
      }
    },
    "replays": {
      "$gameId": {
        ".read": "auth != null && (data.child('createdBy').val() === auth.uid || data.child('participants/' + auth.uid).exists())",
        ".write": "auth != null && ((!data.exists() && newData.child('createdBy').val() === auth.uid) || (data.exists() && data.child('createdBy').val() === auth.uid))"
      }
    },
    "rooms": {
      "$code": {
        ".write": "auth != null && (!data.exists() || data.child('meta/hostUid').val() === auth.uid)",
        "meta": {
          ".read": "auth != null"
        },
        "lobby": {
          ".read": "auth != null",
          "$pid": {
            ".write": "auth != null && $pid === auth.uid && root.child('rooms/' + $code + '/meta/status').val() === 'lobby'"
          }
        },
        "actions": {
          ".read": "auth != null && root.child('rooms/' + $code + '/meta/hostUid').val() === auth.uid",
          "$aid": {
            ".write": "auth != null && newData.child('uid').val() === auth.uid && root.child('rooms/' + $code + '/lobby/' + auth.uid).exists()"
          }
        },
        "views": {
          "$uid": {
            ".read": "auth != null && $uid === auth.uid"
          }
        }
      }
    }
  }
}
